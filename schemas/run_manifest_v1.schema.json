{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunManifestV1",
  "type": "object",
  "properties": {
    "artifacts": {
      "$ref": "#/$defs/RunArtifacts"
    },
    "build": {
      "$ref": "#/$defs/BuildInfo",
      "default": {
        "binary_sha256": "",
        "cargo_lock_sha256": "",
        "dirty_tree": false,
        "git_commit_sha": "",
        "profile": "",
        "target_cpu": "",
        "target_triple": ""
      }
    },
    "compat": {
      "$ref": "#/$defs/RunCompat"
    },
    "config": {
      "$ref": "#/$defs/ConfigFingerprint"
    },
    "created_utc": {
      "type": "string"
    },
    "failure_note": {
      "type": "string"
    },
    "grammar_profile": {
      "type": "string"
    },
    "host": {
      "$ref": "#/$defs/HostInfo"
    },
    "position": {
      "$ref": "#/$defs/RunPosition"
    },
    "run_id": {
      "type": "string"
    },
    "runtime": {
      "$ref": "#/$defs/RuntimeInfo",
      "default": {
        "resolved_worker_count": 0
      }
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "search_policy": {
      "$ref": "#/$defs/SearchPolicyInfo",
      "default": {
        "bucket_policy": "",
        "guidance_style": "",
        "late_expansion_policy": ""
      }
    },
    "status": {
      "$ref": "#/$defs/RunStatus"
    },
    "updated_utc": {
      "type": "string"
    },
    "workspace_version": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "status",
    "created_utc",
    "updated_utc",
    "workspace_version",
    "compat",
    "host",
    "config",
    "position",
    "artifacts"
  ],
  "$defs": {
    "BuildInfo": {
      "type": "object",
      "properties": {
        "binary_sha256": {
          "type": "string",
          "default": ""
        },
        "cargo_lock_sha256": {
          "type": "string",
          "default": ""
        },
        "dirty_tree": {
          "type": "boolean",
          "default": false
        },
        "git_commit_sha": {
          "type": "string",
          "default": ""
        },
        "profile": {
          "type": "string",
          "default": ""
        },
        "target_cpu": {
          "type": "string",
          "default": ""
        },
        "target_triple": {
          "type": "string",
          "default": ""
        }
      }
    },
    "ConfigFingerprint": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256"
      ]
    },
    "HostInfo": {
      "type": "object",
      "properties": {
        "arch": {
          "type": "string",
          "default": ""
        },
        "cpu_model": {
          "type": "string",
          "default": ""
        },
        "logical_cpus": {
          "type": "integer",
          "format": "uint32",
          "default": 0,
          "minimum": 0
        },
        "os": {
          "type": "string",
          "default": ""
        },
        "physical_core_count": {
          "type": "integer",
          "format": "uint32",
          "default": 0,
          "minimum": 0
        },
        "ram_bytes": {
          "type": "integer",
          "format": "uint64",
          "default": 0,
          "minimum": 0
        }
      }
    },
    "RunArtifacts": {
      "type": "object",
      "properties": {
        "checkpoints_dir": {
          "type": "string"
        },
        "reports_dir": {
          "type": "string"
        },
        "telemetry": {
          "type": "string"
        }
      },
      "required": [
        "telemetry",
        "reports_dir",
        "checkpoints_dir"
      ]
    },
    "RunCompat": {
      "type": "object",
      "properties": {
        "ast_schema_hash": {
          "type": "string"
        },
        "evaluator_hash": {
          "type": "string"
        },
        "search_semantics_hash": {
          "type": "string"
        },
        "store_schema_hash": {
          "type": "string"
        },
        "type_rules_hash": {
          "type": "string"
        }
      },
      "required": [
        "ast_schema_hash",
        "type_rules_hash",
        "evaluator_hash",
        "search_semantics_hash",
        "store_schema_hash"
      ]
    },
    "RunPosition": {
      "type": "object",
      "properties": {
        "active_band": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "active_step": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "completed_step": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "frontier_epoch": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "completed_step",
        "active_step",
        "active_band",
        "frontier_epoch"
      ]
    },
    "RunStatus": {
      "type": "string",
      "enum": [
        "running",
        "paused",
        "completed",
        "failed"
      ]
    },
    "RuntimeInfo": {
      "type": "object",
      "properties": {
        "resolved_worker_count": {
          "type": "integer",
          "format": "uint16",
          "default": 0,
          "maximum": 65535,
          "minimum": 0
        }
      }
    },
    "SearchPolicyInfo": {
      "type": "object",
      "properties": {
        "bucket_policy": {
          "type": "string"
        },
        "guidance_style": {
          "type": "string"
        },
        "late_expansion_policy": {
          "type": "string"
        }
      },
      "required": [
        "guidance_style",
        "late_expansion_policy",
        "bucket_policy"
      ]
    }
  }
}
