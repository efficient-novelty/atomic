{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TelemetryEventV1",
  "type": "object",
  "properties": {
    "event": {
      "type": "string"
    },
    "payload": true,
    "run_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "step_index": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint32",
      "minimum": 0
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "event",
    "payload"
  ]
}
